---
interface Props {
  language?: string;
}

const { language = "bash" } = Astro.props;
---

<div class="terminal-block">
  <div class="terminal-header">
    <div class="terminal-dots">
      <span class="dot red"></span>
      <span class="dot yellow"></span>
      <span class="dot green"></span>
    </div>
    <div class="terminal-actions">
      {language && <span class="terminal-lang">{language}</span>}
      <button class="copy-btn" aria-label="Copy to clipboard">Copy</button>
    </div>
  </div>
  <pre class="terminal-pre"><code class="terminal-code"><slot /></code></pre>
</div>

<style>
  .terminal-block {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin: 2rem 0;
    overflow: hidden;
    box-shadow: 0 4px 12px var(--shadow-tint);
  }

  .terminal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1.25rem;
    background: rgba(0, 0, 0, 0.2);
    border-bottom: 1px solid var(--border);
  }

  .terminal-dots {
    display: flex;
    gap: 8px;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .red { background: #ff5f56; }
  .yellow { background: #ffbd2e; }
  .green { background: #27c93f; }

  .terminal-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .terminal-lang {
    font-family: monospace;
    font-size: 0.8rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .copy-btn {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: var(--muted);
    border-radius: 4px;
    padding: 0.2rem 0.6rem;
    font-size: 0.75rem;
    font-family: monospace;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .copy-btn:hover {
    background: rgba(255, 255, 255, 0.25);
    color: #fff;
  }

  .terminal-pre {
    margin: 0 !important;
    padding: 1.25rem !important;
    overflow-x: auto !important;
    /* Reset the global flex layout from the Discord messages */
    display: block !important;
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
  }

  /* Kill the global Discord Avatar placeholder */
  .terminal-pre::before {
    content: none !important;
    display: none !important;
  }

  .terminal-code {
    font-family: monospace !important;
    font-size: 0.95rem !important;
    color: var(--ink) !important;
    background: transparent !important;
    padding: 0 !important;
    display: block !important;
  }

  /* Kill the global "Anon" display name */
  .terminal-code::before {
    content: none !important;
    display: none !important;
  }
</style>

<script>
  const blocks = document.querySelectorAll('.terminal-block');
  
  blocks.forEach((block) => {
    const btn = block.querySelector('.copy-btn');
    const code = block.querySelector('.terminal-code');
    
    if (btn && code) {
      btn.addEventListener('click', async () => {
        try {
          const textToCopy = code.textContent.trim();
          await navigator.clipboard.writeText(textToCopy);
          
          const originalText = btn.textContent;
          btn.textContent = 'Copied!';
          btn.style.color = '#27c93f';
          btn.style.borderColor = '#27c93f';
          
          setTimeout(() => {
            btn.textContent = originalText;
            btn.style.color = '';
            btn.style.borderColor = '';
          }, 2000);
        } catch (err) {
          console.error('Failed to copy text', err);
          btn.textContent = 'Error';
        }
      });
    }
  });
</script>