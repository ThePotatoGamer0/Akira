---
import { getCollection } from "astro:content";
import DocsLayout from "../../layouts/DocsLayout.astro";

type Section = "commands" | "economy" | "prestige" | "getting-started" | "webui";

const titles: Record<Section, string> = {
  commands: "Commands",
  economy: "Economy",
  prestige: "Prestige",
  "getting-started": "Getting started",
  webui: "WebUI",
};

export async function getStaticPaths() {
  const SECTIONS: Section[] = ["commands", "economy", "prestige", "getting-started", "webui"];
  const out: {
    params: { section: Section; slug: string };
    props: { section: Section };
  }[] = [];
  for (const section of SECTIONS) {
    const entries = await getCollection(section);
    for (const entry of entries) {
      out.push({
        params: { section, slug: entry.slug },
        props: { section },
      });
    }
  }
  return out;
}

const { section, slug } = Astro.params as { section: Section; slug: string };
const entries = await getCollection(section);
const entry = entries.find((e) => e.slug === slug);
if (!entry) throw new Error(`Missing entry ${section}/${slug}`);

const { Content } = await entry.render();
---

<DocsLayout frontmatter={entry.data} section={titles[section]} slug={entry.slug}>
  <Content />
</DocsLayout>
